{
  "name": "codebase-docs-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable AI documentation engine for analyzing source-code archives and generating structured technical documentation.",
  "type": "module",
  "packageManager": "pnpm@9.9.0",
  "scripts": {
    "build": "pnpm -r --sort build",
    "dev": "pnpm --parallel --filter @codebase-docs-ai/api --filter @codebase-docs-ai/web dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke:e2e": "tsx scripts/e2e-smoke.ts",
    "test": "vitest run",
    "typecheck": "pnpm -r --sort typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.1",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vitest": "^2.1.8"
  }
}
